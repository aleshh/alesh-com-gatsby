{
  "name": "alesh-com",
  "version": "1.0.0",
  "private": true,
  "description": "alesh-com",
  "author": "Alesh Houdek",
  "keywords": [
    "eleventy",
    "static-site"
  ],
  "scripts": {
    "dev": "eleventy --serve",
    "start": "eleventy --serve",
    "build": "eleventy",
    "serve": "eleventy --serve",
    "clean": "node -e \"require('fs').rmSync('public', { recursive: true, force: true })\"",
    "typecheck": "node --check .eleventy.js && node --check src/site/utils/renderMarkdown.js && node --check src/site/utils/renderPage.js && node --check src/site/assets/app.js && node --check src/site/assets/ghostCursor.js"
  },
  "dependencies": {
    "feather-icons": "^4.29.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5"
  }
}
